<Window x:Class="Pastomatic.Views.ActionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pastomatic.ViewModels"
        Title="Pastomatic"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Dark theme colors -->
        <SolidColorBrush x:Key="BgBrush" Color="#E6202020"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FF2A2A2A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF4A9EFF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF6BB3FF"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#FF3A3A3A"/>
        <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#FF4A4A4A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="SubtextBrush" Color="#FF999999"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#FF4ADE80"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#FFEF4444"/>

        <!-- Button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="16,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgBrush}" CornerRadius="16" Padding="20" Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <!-- Preview State -->
            <StackPanel x:Name="PreviewPanel" Visibility="Visible">
                <!-- Image preview -->
                <Border Background="{StaticResource CardBrush}" CornerRadius="10"
                        Padding="8" Margin="0,0,0,12" MaxHeight="300">
                    <Image x:Name="PreviewImageControl"
                           Source="{Binding PreviewImage}"
                           Stretch="Uniform"
                           MaxHeight="280"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <!-- Image size info -->
                <TextBlock Text="{Binding ImageSizeText}"
                           Foreground="{StaticResource SubtextBrush}"
                           FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- Describe button -->
                <Button Style="{StaticResource ActionButton}"
                        Background="{StaticResource AccentBrush}"
                        Command="{Binding DescribeCommand}"
                        Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Describe with LLM" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Save & Copy Path button -->
                <Button Style="{StaticResource ActionButton}"
                        Background="{StaticResource SecondaryBrush}"
                        Command="{Binding SaveAndCopyCommand}"
                        Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Save &amp; Copy Path" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Escape hint -->
                <TextBlock Text="Escape to close"
                           Foreground="{StaticResource SubtextBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Processing State -->
            <StackPanel x:Name="ProcessingPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                             Height="4" Width="200"
                             Margin="0,0,0,16"
                             Foreground="{StaticResource AccentBrush}"
                             Background="{StaticResource SecondaryBrush}"
                             BorderThickness="0"/>
                <TextBlock x:Name="ProcessingText"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>
                <TextBlock Text="Escape to cancel"
                           Foreground="{StaticResource SubtextBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Success State -->
            <StackPanel x:Name="SuccessPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,20">
                <TextBlock Text="&#x2713;"
                           Foreground="{StaticResource SuccessBrush}"
                           FontSize="48"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Copied to clipboard!"
                           Foreground="{StaticResource SuccessBrush}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <!-- Error State -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,20">
                <TextBlock Text="&#x2717;"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="48"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="ErrorText"
                           Text="{Binding StatusText}"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           MaxWidth="350"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,8"/>
                <TextBlock Text="Escape to close"
                           Foreground="{StaticResource SubtextBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
