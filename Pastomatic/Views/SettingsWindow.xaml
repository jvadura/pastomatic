<Window x:Class="Pastomatic.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Pastomatic"
        Height="480" Width="520"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True"
        ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="10">
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <TextBlock Text="Hotkey:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="HotkeyComboBox" Margin="0,0,0,15">
                            <ComboBoxItem Content="Insert" Tag="Insert" IsSelected="True"/>
                            <ComboBoxItem Content="Print Screen" Tag="PrintScreen"/>
                            <ComboBoxItem Content="Scroll Lock" Tag="ScrollLock"/>
                            <ComboBoxItem Content="Pause/Break" Tag="Pause"/>
                        </ComboBox>

                        <TextBlock Text="Image Save Folder:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SaveFolderTextBox" Grid.Column="0" Margin="0,0,5,0"/>
                            <Button Grid.Column="1" Content="Browse..." Width="70" Click="BrowseButton_Click"/>
                        </Grid>

                        <TextBlock Text="Max Megapixels:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="MaxMegapixelsSlider" Grid.Column="0"
                                    Minimum="0.5" Maximum="8.0" Value="2.0"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ElementName=MaxMegapixelsSlider, Path=Value, StringFormat={}{0:F1}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Clipboard Format:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ClipboardFormatComboBox" Margin="0,0,0,15">
                            <ComboBoxItem Content="{}{wslpath}" Tag="{}{wslpath}"/>
                            <ComboBoxItem Content="{}Read {wslpath}" Tag="{}Read {wslpath}" IsSelected="True"/>
                        </ComboBox>

                        <CheckBox x:Name="CloseOnFocusLossCheckBox"
                                  Content="Close popup on focus loss"
                                  IsChecked="True"
                                  Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Vision LLM Tab -->
            <TabItem Header="Vision LLM">
                <ScrollViewer Margin="10">
                    <StackPanel>
                        <TextBlock Text="API Endpoint:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="EndpointTextBox" Margin="0,0,0,15"/>

                        <TextBlock Text="Model:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="ModelTextBox" Margin="0,0,0,15"/>

                        <TextBlock Text="API Key:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <PasswordBox x:Name="ApiKeyPasswordBox" Margin="0,0,0,15"/>

                        <TextBlock Text="Max Tokens:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="MaxTokensTextBox" Margin="0,0,0,15"/>

                        <TextBlock Text="Temperature:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="TemperatureSlider" Grid.Column="0"
                                    Minimum="0.0" Maximum="1.0" Value="0.1"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ElementName=TemperatureSlider, Path=Value, StringFormat={}{0:F2}}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Timeout (seconds):" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="TimeoutTextBox" Margin="0,0,0,15"/>

                        <TextBlock Text="System Prompt:" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBox x:Name="SystemPromptTextBox"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 Height="100" VerticalScrollBarVisibility="Auto"
                                 Margin="0,0,0,5"/>
                        <Button Content="Reset to Default" Width="120" HorizontalAlignment="Left"
                                Click="ResetPromptButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="SaveButton" Content="Save" Width="80" Margin="0,0,10,0"
                    Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
